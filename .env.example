# DeKalb Database — Environment Variables
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR OAuth Cloud API (api.ibkr.com) — primary integration
# Server-to-server RSA OAuth; no desktop gateway or browser login.
# ---------------------------------------------------------------
IBKR_ENABLED=false
IBKR_ACCOUNT_ID=                    # e.g. U1234567 (client account, not FA master)

IBKR_CLIENT_ID=
IBKR_CLIENT_KEY_ID=main
IBKR_CREDENTIAL=
IBKR_PRIVATE_KEY=                   # PEM, base64 PEM, or \n-escaped PEM
IBKR_SERVER_IP=                     # public outbound IP registered in IBKR OAuth app
IBKR_API_BASE_URL=https://api.ibkr.com

# Optional: legacy Client Portal Gateway (local dev only)
# IBKR_GATEWAY_URL=https://localhost:5001

# ---------------------------------------------------------------
# Frontend URL — used for CORS (comma-separated for multiple origins)
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# PostgreSQL (only needed if overriding defaults)
# ---------------------------------------------------------------
# DB_HOST=localhost
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------
# PRICE_CACHE_TTL_SECONDS=60
# YFINANCE_REQUEST_DELAY_SECONDS=1.5
# IBKR_REQUEST_DELAY_SECONDS=0.35
# IBKR_TX_DAYS=730
# IBKR_SNAPSHOT_MAX_ATTEMPTS=8
# DEBUG=false

# ---------------------------------------------------------------
# Market data
# ---------------------------------------------------------------
# auto = prefer FirstRateData when FIRST_RATE_DATA_PATH exists, then IBKR,
# then yfinance. Set to ibkr or yfinance to bypass FirstRateData.
# MARKET_DATA_PROVIDER=auto

# Point at either the FirstRateData ZIP bundle or an extracted directory.
# FIRST_RATE_DATA_PATH=C:\data\firstratedata_bundle.zip
# FIRST_RATE_DATA_DOWNLOAD_URL=
# FIRST_RATE_DATA_API_KEY=
# FIRST_RATE_DATA_TIMEOUT_SECONDS=120
# BENCHMARK_SYMBOL=SPY

# ---------------------------------------------------------------
# Dashboard compatibility hooks for future quant-division panels
# ---------------------------------------------------------------
# Exposes /dashboard/capabilities so the frontend can discover which
# dashboard modules/contracts exist before visible quant panels are added.
# QUANT_DASHBOARD_COMPAT_ENABLED=false
# QUANT_POSTGRES_DB=trading
# QUANT_QUESTDB_HTTP_URL=http://questdb:9000
# QUANT_QUESTDB_ILP_HOST=questdb
# QUANT_EVENT_SOURCE=ingestion-service

# ---------------------------------------------------------------
# Production / deployment only (Railway + Cloudflare Pages)
# ---------------------------------------------------------------
# DATABASE_URL=postgres://user:pass@host:port/dbname
# DB_SSL=require
# DB_MIN_CONNECTIONS=2
# DB_MAX_CONNECTIONS=10
# DB_CONNECT_RETRIES=12
# DB_CONNECT_RETRY_SECONDS=5

# AUTH_ENABLED=false
# GOOGLE_CLIENT_ID=
# ALLOWED_EMAIL_DOMAIN=dekalbcapitalmanagement.com
