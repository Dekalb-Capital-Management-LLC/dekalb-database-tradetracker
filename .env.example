# DeKalb Database — Environment Variables
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR OAuth Cloud API (api.ibkr.com) — primary integration
# Server-to-server RSA OAuth; no desktop gateway or browser login.
# ---------------------------------------------------------------
IBKR_ENABLED=false
IBKR_ACCOUNT_ID=                    # e.g. U1234567 (client account, not FA master)

IBKR_CLIENT_ID=
IBKR_CLIENT_KEY_ID=main
IBKR_CREDENTIAL=
IBKR_PRIVATE_KEY=                   # PEM, base64 PEM, or \n-escaped PEM
IBKR_SERVER_IP=                     # public outbound IP registered in IBKR OAuth app
IBKR_API_BASE_URL=https://api.ibkr.com

# Optional: legacy Client Portal Gateway (local dev only)
# IBKR_GATEWAY_URL=https://localhost:5001

# ---------------------------------------------------------------
# Frontend URL — used for CORS (comma-separated for multiple origins)
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# PostgreSQL (only needed if overriding defaults)
# ---------------------------------------------------------------
# DB_HOST=localhost
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------
# PRICE_CACHE_TTL_SECONDS=60
# YFINANCE_REQUEST_DELAY_SECONDS=1.5
# IBKR_REQUEST_DELAY_SECONDS=0.35
# IBKR_TX_DAYS=730
# IBKR_SNAPSHOT_MAX_ATTEMPTS=8
# DEBUG=false

# ---------------------------------------------------------------
# Production / deployment only (Railway + Cloudflare Pages)
# ---------------------------------------------------------------
# DATABASE_URL=postgres://user:pass@host:port/dbname
# DB_SSL=require

# AUTH_ENABLED=false
# GOOGLE_CLIENT_ID=
# ALLOWED_EMAIL_DOMAIN=dekalbcapitalmanagement.com
