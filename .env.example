# DeKalb Database — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# The .env file is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR Client Portal Gateway
# ---------------------------------------------------------------
# Your IBKR account ID. Find it in IBKR → Account → Account Summary.
# Format: U followed by digits, e.g. U1234567
IBKR_ACCOUNT_ID=

# Set to true once the gateway is running and you've authenticated in the browser.
# When false, the API falls back to yfinance for market data.
IBKR_ENABLED=false

# Where the gateway is listening.
# - Local (running API directly): https://localhost:5001
# - Docker (running via docker-compose): https://host.docker.internal:5001
IBKR_GATEWAY_URL=https://localhost:5001

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
# Only needed if you're overriding the defaults.
# Default: localhost for local dev, set to 'postgres' in Docker (handled by docker-compose).
# DB_HOST=localhost
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Trade Tracker API tuning (optional)
# ---------------------------------------------------------------
# How long to cache yfinance price lookups before re-fetching (seconds)
# PRICE_CACHE_TTL_SECONDS=60

# Enable verbose debug logging
# DEBUG=false

# ---------------------------------------------------------------
# Production / deployment only (Railway + Vercel)
# ---------------------------------------------------------------
# Set automatically by Railway when you provision a Postgres plugin.
# Format: postgres://user:pass@host:port/dbname
# DATABASE_URL=

# Required when DATABASE_URL is set (Railway Postgres requires SSL).
# DB_SSL=require

# Turn on Google Workspace SSO for the frontend.
# AUTH_ENABLED=false
# GOOGLE_CLIENT_ID=
# ALLOWED_EMAIL_DOMAIN=dekalbcapitalmanagement.com

# Deployed frontend origin(s), comma-separated. Required for CORS when
# AUTH_ENABLED=true and the frontend is on a different domain (e.g. Vercel).
# FRONTEND_URL=https://dekalb-trade-tracker.vercel.app
